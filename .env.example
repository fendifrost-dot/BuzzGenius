# Site URL (used for Stripe redirect URLs)
SITE_URL=http://localhost:8080
VITE_SITE_URL=http://localhost:8080

# Supabase (contact form)
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=

# Stripe — client (publishable key only)
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_...

# Stripe — server (NEVER expose in Vite/VITE_ vars)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Stripe Price IDs (server-side; create in Stripe Dashboard → Products)
# Map to the four consulting packages (Service Overview / Pricing Structure):
STRIPE_PRICE_STRATEGY_SESSION=price_...   # $1,000
STRIPE_PRICE_GROWTH_OPS=price_...          # $3,000
STRIPE_PRICE_BUSINESS_DEV=price_...        # $5,000
STRIPE_PRICE_ADVANCED_ADVISORY=price_...   # $6,000

# Local API dev server port (default 3001)
API_PORT=3001
