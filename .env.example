# Site URL (used for Stripe redirect URLs)
SITE_URL=http://localhost:8080
VITE_SITE_URL=http://localhost:8080

# Supabase (contact form)
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=

# Stripe — client (publishable key only)
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_...

# Stripe — server (NEVER expose in Vite/VITE_ vars)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Stripe Price IDs (server-side; create in Stripe Dashboard → Products)
STRIPE_PRICE_SOCIAL_STARTER=price_...
STRIPE_PRICE_GROWTH=price_...
STRIPE_PRICE_BRAND=price_...
STRIPE_PRICE_WEBSITE=price_...
STRIPE_PRICE_AUTOMATION=price_...

# Local API dev server port (default 3001)
API_PORT=3001
